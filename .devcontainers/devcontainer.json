// For format details, see https://aka.ms/devcontainer.json.
// For config options, see https://containers.dev/.
// To share Git ssh keys with the container on macOS, run on the LOCAL terminal:
//   ssh-add ~/.ssh/id_ed25519
{
    "name": "xlwings Server",
    "image": "mcr.microsoft.com/devcontainers/python:3-3.14-bookworm",
    // Recommended uv settings inside containers. UV_LINK_MODE=copy avoids
    // cross-filesystem hardlink warnings (esp. on GitHub Codespaces, where the
    // workspace and ~/.cache live on different filesystems).
    "containerEnv": {
        "UV_LINK_MODE": "copy",
        "UV_COMPILE_BYTECODE": "1"
    },
    // Forward FastAPI dev server.
    "forwardPorts": [8000],
    // Install uv and sync dependencies.
    "postCreateCommand": "pip install --user --upgrade uv && uv sync",
    // pre-commit and git need this when the workspace is bind-mounted.
    "postStartCommand": "git config --global --add safe.directory ${containerWorkspaceFolder}",
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-python.python",
                "charliermarsh.ruff",
                "samuelcolvin.jinjahtml",
                "tamasfe.even-better-toml"
            ],
            "settings": {
                "python.defaultInterpreterPath": "${containerWorkspaceFolder}/.venv/bin/python",
                "[python]": {
                    "editor.defaultFormatter": "charliermarsh.ruff",
                    "editor.formatOnSave": true,
                    "editor.codeActionsOnSave": {
                        "source.organizeImports": "explicit"
                    }
                }
            }
        }
    },
    "remoteUser": "vscode"
}
